{
  "name": "cpq-app",
  "private": true,
  "version": "0.2.0",
  "description": "CPQ app for pricing stainless steel vessels via multi-level BOM (React client + Express/Postgres API)",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "cross-env PORT=3001 tsx watch server/index.ts",
    "build": "prisma generate && vite build",
    "start": "prisma migrate deploy && tsx server/index.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^9.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
